<table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
        <td align="center">
            <#if title??>
            <p style="margin: 5px 0; font-size: 16px; text-align: center;">${title}</p>
            </#if>
            <p style="margin: 10px 0; font-size: 48px; font-weight: bold; text-align: center;">${value}</p>
            <#if subtitle??>
            <p style="margin: 5px 0; font-size: 16px; text-align: center;">${subtitle}</p>
            </#if>
        </td>
    </tr>
</table>
